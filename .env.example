# Sanity CMS Configuration (Optional - for future CMS integration)
# These are public environment variables (prefixed with NEXT_PUBLIC_)
# They are safe to expose in the frontend bundle

# Sanity Project ID (public)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Sanity Dataset (public)
NEXT_PUBLIC_SANITY_DATASET=production

# Note: The website currently uses placeholder data and does not require
# these environment variables to function. They are prepared for future
# Sanity CMS integration.

# DO NOT add private API keys, tokens, or secrets to this file.
# Private environment variables should never be prefixed with NEXT_PUBLIC_
# and should only be used in server-side code (API routes, server components).

# ============================================
# SMTP Email Configuration (Server-side only)
# ============================================
# Required for contact form email delivery
# These are PRIVATE variables - do NOT prefix with NEXT_PUBLIC_

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# SMTP Authentication
# For Gmail: Use App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# Email sender (usually same as SMTP_USER)
SMTP_FROM=your-email@gmail.com

# IMPORTANT SECURITY NOTES:
# 1. Never commit the actual .env file to Git
# 2. Use App Passwords for Gmail (not regular passwords)
# 3. For production, use a dedicated email service (SendGrid, AWS SES, etc.)
# 4. Keep these credentials secret and secure
