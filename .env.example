# Sanity CMS Configuration (Optional - for future CMS integration)
# These are public environment variables (prefixed with NEXT_PUBLIC_)
# They are safe to expose in the frontend bundle

# Sanity Project ID (public)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Sanity Dataset (public)
NEXT_PUBLIC_SANITY_DATASET=production

# Note: The website currently uses placeholder data and does not require
# these environment variables to function. They are prepared for future
# Sanity CMS integration.

# DO NOT add private API keys, tokens, or secrets to this file.
# Private environment variables should never be prefixed with NEXT_PUBLIC_
# and should only be used in server-side code (API routes, server components).
