# Sanity CMS Configuration (Optional - for future CMS integration)
# These are public environment variables (prefixed with NEXT_PUBLIC_)
# They are safe to expose in the frontend bundle

# Sanity Project ID (public)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Sanity Dataset (public)
NEXT_PUBLIC_SANITY_DATASET=production

# Note: The website currently uses placeholder data and does not require
# these environment variables to function. They are prepared for future
# Sanity CMS integration.

# DO NOT add private API keys, tokens, or secrets to this file.
# Private environment variables should never be prefixed with NEXT_PUBLIC_
# and should only be used in server-side code (API routes, server components).

# ============================================
# SMTP Email Configuration (Server-side only - DO NOT expose in frontend)
# These are used by the contact form API route to send emails
# Configure your SMTP provider (Gmail, SendGrid, AWS SES, etc.)

# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-email@gmail.com

# SendGrid example:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=noreply@yourdomain.com

# AWS SES example:
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-aws-access-key-id
# SMTP_PASS=your-aws-secret-access-key
# SMTP_FROM=noreply@yourdomain.com

# Telegram Notifications (Server-side only - DO NOT expose in frontend)
# Get your bot token from @BotFather on Telegram
# Get your chat ID by messaging your bot and checking https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# IMPORTANT SECURITY NOTES:
# 1. Never commit the actual .env file to Git
# 2. Use App Passwords for Gmail (not regular passwords)
# 3. For production, use a dedicated email service (SendGrid, AWS SES, etc.)
# 4. Keep these credentials secret and secure
